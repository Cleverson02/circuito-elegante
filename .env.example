# ============================================
# STELLA — Concierge Digital do Circuito Elegante
# Environment Configuration Template
# ============================================
# Copy to .env and fill in your credentials
# DO NOT commit .env with real values
# ============================================

# ============================================================
# CORE RUNTIME
# ============================================================
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# ============================================================
# OPENAI (OBRIGATÓRIO — 4 agentes da Stella)
# Get key at: https://platform.openai.com/api-keys
# ============================================================
OPENAI_API_KEY=

# ============================================================
# SUPABASE / POSTGRES (OBRIGATÓRIO — Story 1.2+)
# Get from Supabase project settings:
#   Dashboard → Project Settings → API
#   Dashboard → Project Settings → Database → Connection string
# ============================================================
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Connection string direta para Drizzle ORM / migrations
# Formato: postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
DATABASE_URL=

# ============================================================
# REDIS (OBRIGATÓRIO — Story 1.5+)
# Session state, rate limiting, buffer, idempotência
# Local Docker: redis://localhost:6379
# ============================================================
REDIS_URL=redis://localhost:6379

# ============================================================
# EVOLUTION API (OBRIGATÓRIO — Epic 4 WhatsApp)
# Install: https://doc.evolution-api.com/
# ============================================================
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE_NAME=stella-whatsapp
EVOLUTION_WEBHOOK_SECRET=

# ============================================================
# ELEVARE API (OBRIGATÓRIO — Epic 3 reservas/pagamentos)
# 32 hotéis integrados via API — 60 hotéis manuais (fallback humano)
#
# Auth: a API usa DOIS headers em toda requisição:
#   - x-client-id: {ELEVARE_CLIENT_ID}
#   - x-client-secret: {ELEVARE_CLIENT_SECRET}
# URL oficial de produção: https://api.elevare.com.br/api/v1
# Todos endpoints são prefixados com /global-agent/
# ============================================================
ELEVARE_API_URL=https://api.elevare.com.br/api/v1
ELEVARE_CLIENT_ID=
ELEVARE_CLIENT_SECRET=
ELEVARE_WEBHOOK_SECRET=
ELEVARE_TIMEOUT_MS=8000
ELEVARE_MAX_RETRIES=3

# ============================================================
# CHATWOOT (OBRIGATÓRIO — Handover humano Epic 5)
# Self-hosted ou SaaS: https://www.chatwoot.com/
# ============================================================
CHATWOOT_API_URL=
CHATWOOT_API_TOKEN=
CHATWOOT_ACCOUNT_ID=1

# ============================================================
# GOOGLE DRIVE (OPCIONAL — Story 1.4 FAQ sync)
# Service account JSON key (one-line) + folder ID
# ============================================================
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_SERVICE_ACCOUNT_KEY=

# ============================================================
# MONITORING (OPCIONAL)
# ============================================================
SENTRY_DSN=

# ============================================================
# RATE LIMITING (defaults já funcionam)
# ============================================================
RATE_LIMIT_PER_MINUTE=30
RATE_LIMIT_PER_DAY=500
