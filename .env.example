# ============================================
# Stella — Concierge Digital (Circuito Elegante)
# ============================================
# Copy to .env and fill in actual values.
# DO NOT commit .env with real credentials.
# Production: inject via Digital Ocean App Platform / CI secrets.
# ============================================

# Core
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Database (Supabase)
DATABASE_URL=postgresql://postgres:password@localhost:5432/stella
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Redis
REDIS_URL=redis://localhost:6379

# OpenAI
OPENAI_API_KEY=sk-xxx

# Evolution API
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE_NAME=stella-whatsapp

# Elevare API
ELEVARE_API_URL=https://api.elevare.com.br/v1
ELEVARE_API_KEY=

# Chatwoot
CHATWOOT_API_URL=https://chatwoot.circuitoelegante.com.br/api/v1
CHATWOOT_API_TOKEN=
CHATWOOT_ACCOUNT_ID=1

# Google Drive (FAQ Sync)
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_SERVICE_ACCOUNT_KEY=

# Sentry
SENTRY_DSN=

# Rate Limiting
RATE_LIMIT_PER_MINUTE=30
RATE_LIMIT_PER_DAY=500

# ============================================
# AIOX Framework (dev tooling only)
# ============================================
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
EXA_API_KEY=
CONTEXT7_API_KEY=
GITHUB_TOKEN=
CLICKUP_API_KEY=
N8N_API_KEY=
N8N_WEBHOOK_URL=
RAILWAY_TOKEN=
VERCEL_TOKEN=
AIOX_VERSION=2.2.0
